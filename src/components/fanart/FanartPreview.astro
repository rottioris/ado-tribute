---
import FanartScroller from './FanartScroller.tsx';
---

<section id="fanart-preview">

  <!-- Fades de fusión con secciones vecinas — z-index alto, no rotan -->
  <div class="fa-fade-top"    aria-hidden="true"></div>
  <div class="fa-fade-bottom" aria-hidden="true"></div>

  <!-- Fondo animado inclinado -->
  <div class="fa-bg" aria-hidden="true">
    <div class="fa-stage">
      <FanartScroller client:load />
    </div>
    <div class="fa-overlay"></div>
  </div>

  <!-- Contenido encima -->
  <div class="inner fa-content">
    <div>
      <p class="s-label">01 — ファンアート</p>
      <h2 class="s-title">Fan Art</h2>
      <p class="s-sub">Arte de fans de todo el mundo · ファンアート</p>
    </div>
    <div class="fa-footer">
      <a href="/fanarts" class="btn-outline">Ver galería completa →</a>
      <span class="fa-count"><span class="fa-num" id="faCount">—</span> obras</span>
    </div>
  </div>

</section>

<style>
  /* Keyframes para el scroller — deben estar en el CSS del componente Astro
     porque los inline styles de React no pueden definir @keyframes */
  @keyframes fs-scroll-up {
    from { transform: translateY(0); }
    to   { transform: translateY(-33.333%); }
  }
  @keyframes fs-scroll-down {
    from { transform: translateY(-33.333%); }
    to   { transform: translateY(0); }
  }

  /* ── Sección ── */
  #fanart-preview {
    position: relative;
    background: var(--void);
    height: 500px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  /* ── Wrapper de la rotación ──
     La clave: expandir el contenedor ANTES de rotar
     usando inset negativo calculado para cubrir exactamente las esquinas.
     inset vertical: -(W*sin(12°) + H*(1-cos(12°)))/2 ≈ -215px
     inset horizontal: -(H*sin(12°))/2 ≈ -70px
     Con margen extra de seguridad.
  */
  .fa-bg {
    position: absolute;
    inset: -220px -80px;   /* Expansión pre-rotación */
    transform: rotate(-12deg);
    transform-origin: center center;
    overflow: visible;      /* Nunca cortar aquí */
  }

  /* Stage interno que ocupa TODO el fa-bg expandido */
  .fa-stage {
    width: 100%;
    height: 100%;
    overflow: hidden;       /* Cortar solo dentro del stage ya expandido */
  }

  /* ── Overlay ──
     Sin gradientes de esquina — estos causaban la línea negra
     al superponerse con el fade global de section::before/after.
     Solo radial central para legibilidad del texto.
     El corte de esquinas lo hace overflow:hidden de #fanart-preview.
  */
  .fa-overlay {
    position: absolute;
    inset: 220px 80px;
    transform: rotate(12deg);
    transform-origin: center center;
    /* Solo oscuro central — sin gradientes de esquina */
    background: radial-gradient(
      ellipse 70% 60% at 50% 50%,
      rgba(4,5,10,.42) 0%,
      rgba(4,5,10,.72) 100%
    );
  }

  /* ── Contenido encima ── */
  .fa-content {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .fa-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .fa-count {
    font-family: var(--mono);
    font-size: .58rem;
    color: var(--wdim);
    letter-spacing: .15em;
  }
  .fa-num {
    color: var(--teal2);
    font-size: .75rem;
    font-weight: 700;
    margin-right: .3rem;
  }

  /* ── Fades de fusión ──
     Capas independientes, z-index:3, encima de todo.
     Altura generosa (100px) para que el fundido sea suave.
     No usan section::before/after para evitar superposición. */
  .fa-fade-top,
  .fa-fade-bottom {
    position: absolute;
    left: 0; right: 0;
    height: 100px;
    pointer-events: none;
    z-index: 3;
  }
  .fa-fade-top {
    top: 0;
    background: linear-gradient(to bottom, var(--void) 0%, transparent 100%);
  }
  .fa-fade-bottom {
    bottom: 0;
    background: linear-gradient(to top, var(--void) 0%, transparent 100%);
  }

  @media (max-width: 768px) {
    #fanart-preview { height: 380px; }
    .fa-bg { inset: -160px -60px; }
    .fa-overlay { inset: 160px 60px; }
  }
  @media (max-width: 480px) {
    #fanart-preview { height: 300px; }
  }
</style>
