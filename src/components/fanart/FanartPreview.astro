---
import FanartScroller from './FanartScroller.tsx';
---

<section id="fanart-preview">

  <!-- Fondo animado inclinado -->
  <div class="fa-bg" aria-hidden="true">
    <div class="fa-stage">
      <FanartScroller client:load />
    </div>
    <div class="fa-overlay"></div>
  </div>

  <!-- Contenido encima -->
  <div class="inner fa-content">
    <div>
      <p class="s-label">01 — ファンアート</p>
      <h2 class="s-title">Fan Art</h2>
      <p class="s-sub">Arte de fans de todo el mundo · ファンアート</p>
    </div>
    <div class="fa-footer">
      <a href="/fanarts" class="btn-outline">Ver galería completa →</a>
      <span class="fa-count"><span class="fa-num" id="faCount">—</span> obras</span>
    </div>
  </div>

</section>

<style>
  /* Keyframes para el scroller — deben estar en el CSS del componente Astro
     porque los inline styles de React no pueden definir @keyframes */
  @keyframes fs-scroll-up {
    from { transform: translateY(0); }
    to   { transform: translateY(-33.333%); }
  }
  @keyframes fs-scroll-down {
    from { transform: translateY(-33.333%); }
    to   { transform: translateY(0); }
  }

  /* ── Sección ── */
  #fanart-preview {
    position: relative;
    background: var(--void);
    height: 500px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  /* ── Wrapper de la rotación ──
     La clave: expandir el contenedor ANTES de rotar
     usando inset negativo calculado para cubrir exactamente las esquinas.
     inset vertical: -(W*sin(12°) + H*(1-cos(12°)))/2 ≈ -215px
     inset horizontal: -(H*sin(12°))/2 ≈ -70px
     Con margen extra de seguridad.
  */
  .fa-bg {
    position: absolute;
    inset: -220px -80px;   /* Expansión pre-rotación */
    transform: rotate(-12deg);
    transform-origin: center center;
    overflow: visible;      /* Nunca cortar aquí */
  }

  /* Stage interno que ocupa TODO el fa-bg expandido */
  .fa-stage {
    width: 100%;
    height: 100%;
    overflow: hidden;       /* Cortar solo dentro del stage ya expandido */
  }

  /* ── Overlay ──
     Cubre esquinas con negro sólido + radial central + fade top/bottom
  */
  .fa-overlay {
    position: absolute;
    /* El overlay NO rota — cubre el viewport original */
    inset: 220px 80px;    /* Compensa el inset del padre para quedar en posición real */
    transform: rotate(12deg); /* Contrarrota para quedar horizontal */
    transform-origin: center center;

    background:
      /* Esquinas negras sólidas — método más confiable */
      linear-gradient(135deg, var(--void) 12%, transparent 32%),
      linear-gradient(225deg, var(--void) 12%, transparent 32%),
      linear-gradient(315deg, var(--void) 12%, transparent 32%),
      linear-gradient( 45deg, var(--void) 12%, transparent 32%),
      /* Oscuro central para texto encima */
      radial-gradient(ellipse 65% 55% at 50% 50%,
        rgba(4,5,10,.48) 0%,
        rgba(4,5,10,.78) 100%
      );

    /* Fade top/bottom para fundirse con secciones vecinas */
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent  0%,
      black        14%,
      black        86%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      transparent  0%,
      black        14%,
      black        86%,
      transparent 100%
    );
  }

  /* ── Contenido encima ── */
  .fa-content {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .fa-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .fa-count {
    font-family: var(--mono);
    font-size: .58rem;
    color: var(--wdim);
    letter-spacing: .15em;
  }
  .fa-num {
    color: var(--teal2);
    font-size: .75rem;
    font-weight: 700;
    margin-right: .3rem;
  }

  @media (max-width: 768px) {
    #fanart-preview { height: 380px; }
    .fa-bg { inset: -160px -60px; }
    .fa-overlay { inset: 160px 60px; }
  }
  @media (max-width: 480px) {
    #fanart-preview { height: 300px; }
  }
</style>
