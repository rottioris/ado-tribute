---
export interface Props {
  active?: 'home' | 'fanarts' | 'messages' | 'profile';
}
const { active = 'home' } = Astro.props;
---

<nav id="nav">
  <a href="/" class="nav-logo">Ado Tribute</a>

  <ul class="nav-links" id="navLinks">
    <li><a href="/fanarts"  class:list={[{ active: active === 'fanarts'  }]}>Fan Art</a></li>
    <li><a href="/messages" class:list={[{ active: active === 'messages' }]}>Mensajes</a></li>
    <li>
      <!-- Google icon only, no text, no border -->
      <a href="/profile" class="nav-profile" class:list={[{ active: active === 'profile' }]} aria-label="Perfil / Iniciar sesión">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path fill="white" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="white" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="white" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="white" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
      </a>
    </li>
  </ul>

  <!-- Hamburger -->
  <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile drawer -->
<div class="nav-drawer" id="navDrawer" aria-hidden="true">
  <a href="/fanarts">Fan Art</a>
  <a href="/messages">Mensajes</a>
  <a href="/profile" class="drawer-profile">
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
      <path fill="white" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="white" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="white" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
      <path fill="white" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
    Iniciar sesión
  </a>
</div>

<script>
  const nav    = document.getElementById('nav')!;
  const burger = document.getElementById('hamburger')!;
  const drawer = document.getElementById('navDrawer')!;
  let open = false;

  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  });

  burger.addEventListener('click', () => {
    open = !open;
    burger.setAttribute('aria-expanded', String(open));
    burger.classList.toggle('is-open', open);
    drawer.classList.toggle('is-open', open);
    drawer.setAttribute('aria-hidden', String(!open));
  });

  document.addEventListener('click', (e) => {
    if (open && !nav.contains(e.target as Node) && !drawer.contains(e.target as Node)) {
      open = false;
      burger.setAttribute('aria-expanded', 'false');
      burger.classList.remove('is-open');
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
    }
  });
</script>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 300;
    padding: 1.2rem 3rem;
    display: flex; justify-content: space-between; align-items: center;
    background: linear-gradient(to bottom, rgba(4,5,10,.95), transparent);
    backdrop-filter: blur(8px);
    transition: background .3s;
  }
  nav.scrolled { background: rgba(4,5,10,.92); }

  .nav-logo {
    font-family: var(--ship); font-size: 1.1rem;
    color: var(--teal); letter-spacing: .2em; white-space: nowrap;
  }

  .nav-links {
    display: flex; align-items: center; gap: 2rem; list-style: none;
  }
  .nav-links a {
    color: var(--wdim); font-family: var(--mono); font-size: .6rem;
    letter-spacing: .15em; text-transform: uppercase; transition: color .3s;
  }
  .nav-links a:hover, .nav-links a.active { color: var(--teal2); }

  /* Google icon — sin borde, sin texto, solo icono */
  .nav-profile {
    display: flex; align-items: center;
    opacity: .65; transition: opacity .3s;
    border: none !important; background: none !important; padding: 0;
  }
  .nav-profile:hover { opacity: 1; }

  /* Hamburger */
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: .4rem; z-index: 310;
  }
  .hamburger span {
    display: block; width: 22px; height: 1.5px; background: var(--teal2);
    transition: transform .3s, opacity .3s; transform-origin: center;
  }
  .hamburger.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Drawer */
  .nav-drawer {
    display: none; position: fixed; top: 0; right: 0;
    height: 100vh; width: min(280px, 80vw);
    background: rgba(8,12,20,.97); border-left: 1px solid rgba(58,127,163,.18);
    backdrop-filter: blur(12px); z-index: 290;
    flex-direction: column; padding: 5.5rem 2rem 2rem; gap: .5rem;
    transform: translateX(100%); transition: transform .3s ease;
  }
  .nav-drawer.is-open { transform: translateX(0); }
  .nav-drawer a {
    font-family: var(--mono); font-size: .7rem; letter-spacing: .2em;
    text-transform: uppercase; color: var(--wdim);
    padding: .9rem 0; border-bottom: 1px solid rgba(58,127,163,.1); transition: color .3s;
  }
  .nav-drawer a:hover { color: var(--teal2); }

  .drawer-profile {
    display: flex !important; align-items: center; gap: .6rem;
    margin-top: 1rem;
    border: 1px solid rgba(58,127,163,.3) !important;
    border-bottom: 1px solid rgba(58,127,163,.3) !important;
    border-radius: 2px; padding: .7rem 1rem !important;
  }

  @media (max-width: 640px) {
    nav { padding: 1rem 1.4rem; }
    .nav-links  { display: none; }
    .hamburger  { display: flex; }
    .nav-drawer { display: flex; }
  }
</style>
