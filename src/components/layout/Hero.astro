---
---

<section id="hero">

  <div class="hero-video-wrap">
    <video id="heroBg" autoplay muted loop playsinline preload="none" aria-hidden="true">
      <source src="/video/Ado_Vivarium.webm" type="video/webm" />
    </video>
    <div class="hero-overlay"></div>
  </div>

  <canvas id="heroBubbles" aria-hidden="true"></canvas>
  <div class="caustic" aria-hidden="true"></div>

  <div class="hero-content">
    <p class="hero-top">Fan Tribute · ファントリビュート · 2026</p>

    <h1 class="hero-title">
      <span class="a-wrap">
        <span class="a">A</span>
        <img src="/images/ado-rose.png" alt="" class="hero-logo" aria-hidden="true" draggable="false" />
      </span><span class="do">do</span>
    </h1>

    <p class="hero-lyric">
      Fan Tribute &nbsp;·&nbsp; ファンサイト &nbsp;·&nbsp; 2026
    </p>

    <div class="hero-langs">
      <div class="hl-item"><span>Español</span>Para ti, con amor</div>
      <div class="hl-item"><span>English</span>For you, with love</div>
      <div class="hl-item"><span>日本語</span>あなたへ、愛を込めて</div>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>

</section>

<script>
  const vid = document.getElementById('heroBg') as HTMLVideoElement;
  if (vid) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      vid.pause(); vid.removeAttribute('autoplay');
    } else {
      new IntersectionObserver(
        ([e]) => { e.isIntersecting ? vid.play().catch(() => {}) : vid.pause(); },
        { threshold: 0.1 }
      ).observe(vid);
    }
  }

  (function () {
    const cv = document.getElementById('heroBubbles') as HTMLCanvasElement;
    if (!cv) return;
    const ctx = cv.getContext('2d')!;
    let W = 0, H = 0;
    interface B { x:number; y:number; r:number; alpha:number; speed:number; wobble:number; wSpeed:number; t:number; }
    let bubbles: B[] = [];

    function resize() { W = cv.width = window.innerWidth; H = cv.height = window.innerHeight; }
    function spawn(sy?: number): B {
      return { x: Math.random()*W, y: sy ?? H+Math.random()*80, r: 3+Math.random()*14,
        alpha: 0.03+Math.random()*0.1, speed: 0.18+Math.random()*0.45,
        wobble: 0.4+Math.random()*0.9, wSpeed: 0.006+Math.random()*0.01, t: Math.random()*Math.PI*2 };
    }

    function draw() {
      ctx.clearRect(0,0,W,H);
      bubbles.forEach((b,i) => {
        b.t += b.wSpeed; b.y -= b.speed; b.x += Math.sin(b.t)*b.wobble;
        if (b.y+b.r < 0) { bubbles[i]=spawn(); return; }
        const p = 1-b.y/H;
        const a = b.alpha * Math.min(p*4,1) * Math.min((1-p)*5,1);
        const g = ctx.createRadialGradient(b.x-b.r*.28,b.y-b.r*.28,b.r*.05,b.x,b.y,b.r);
        g.addColorStop(0,`rgba(200,230,250,${a*.5})`);
        g.addColorStop(.5,`rgba(58,127,163,${a*.25})`);
        g.addColorStop(1,`rgba(30,50,90,0)`);
        ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2); ctx.fillStyle=g; ctx.fill();
        ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2);
        ctx.strokeStyle=`rgba(167,216,240,${a*.6})`; ctx.lineWidth=0.5; ctx.stroke();
        ctx.beginPath(); ctx.arc(b.x-b.r*.32,b.y-b.r*.32,b.r*.18,0,Math.PI*2);
        ctx.fillStyle=`rgba(230,245,255,${a*.7})`; ctx.fill();
      });
      requestAnimationFrame(draw);
    }
    resize();
    for (let i=0;i<30;i++) bubbles.push(spawn(Math.random()*H));
    window.addEventListener('resize', resize);
    draw();
  })();
</script>

<style>
  #hero {
    position: relative; height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; overflow: hidden;
    background: var(--void);
  }

  .hero-video-wrap { position: absolute; inset: 0; z-index: 0; overflow: hidden; }

  /*
    Video cuadrado / no 16:9 → técnica correcta:
    Posicionar desde el centro con top/left 50% + translate -50%
    y definir tamaño mínimo en ambas dimensiones.
    NO usar inset:0 + transform juntos (se contradicen).
    min(100vw * ratio, 100vh * ratio) garantiza cobertura total.
  */
  #heroBg {
    position: absolute;
    top: 50%;
    left: 50%;
    /* Ancho y alto mínimos para cubrir el viewport en cualquier ratio */
    width: auto;
    height: auto;
    min-width: 100vw;
    min-height: 100vh;
    /* Para ratio cuadrado (1:1): necesitamos escalar más */
    /* max() asegura que si el video es cuadrado cubra en landscape */
    transform: translate(-50%, -50%);
  }

  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      rgba(4,5,10,.72) 0%, rgba(4,5,10,.35) 35%,
      rgba(4,5,10,.40) 65%, rgba(4,5,10,.78) 100%);
  }

  #heroBubbles {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    z-index: 2; pointer-events: none;
  }

  .caustic {
    position: absolute; inset: 0; z-index: 3; pointer-events: none;
    background:
      repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(58,127,163,.012) 40px, rgba(58,127,163,.012) 41px),
      repeating-linear-gradient(-45deg, transparent, transparent 60px, rgba(167,216,240,.008) 60px, rgba(167,216,240,.008) 61px);
    animation: causticMove 8s ease-in-out infinite alternate;
  }
  @keyframes causticMove {
    from { background-position: 0 0, 0 0; }
    to   { background-position: 40px 40px, 60px 60px; }
  }

  .hero-content { position: relative; z-index: 5; }

  .hero-top {
    font-family: var(--mono); font-size: .62rem; letter-spacing: .5em;
    color: var(--teal); text-transform: uppercase; margin-bottom: 1.6rem;
    opacity: 0; animation: fadeUp 1.2s ease forwards .4s;
  }

  .hero-title {
    font-family: var(--display);
    font-size: clamp(5rem, 18vw, 12rem);
    font-weight: 400; line-height: .88;
    font-style: italic;                  /* ← cursiva */
    opacity: 0; animation: fadeUp 1.2s ease forwards .75s;
    overflow: visible;
    display: flex; align-items: baseline; justify-content: center; gap: 0;
  }

  .a-wrap { position: relative; display: inline-block; }
  .a  { color: var(--teal); }
  .do { color: rgba(167,216,240,.9); }

  .hero-logo {
    --logo-top:  25%;
    --logo-left: 16%;
    --logo-size: 55%;
    position: absolute;
    top: var(--logo-top); left: var(--logo-left); width: var(--logo-size);
    height: auto; pointer-events: none; user-select: none;
    filter: drop-shadow(0 0 12px rgba(58,127,163,.55));
    opacity: 0; animation: fadeUp 1.2s ease forwards .75s;
  }

  .hero-lyric {
    font-family: var(--ship); font-size: clamp(.75rem,1.8vw,.95rem);
    color: var(--wdim); letter-spacing: .18em; margin-top: 1.8rem;
    font-weight: 300; font-style: italic;
    opacity: 0; animation: fadeUp 1.2s ease forwards 1.1s;
  }

  .hero-langs {
    display: flex; gap: 2.5rem; justify-content: center; margin-top: 2.5rem;
    opacity: 0; animation: fadeUp 1.2s ease forwards 1.4s;
  }
  .hl-item { font-family: var(--ship); font-size: .88rem; color: var(--wdim); }
  .hl-item span {
    display: block; font-family: var(--mono); font-size: .52rem;
    color: rgba(167,216,240,.28); letter-spacing: .22em;
    text-transform: uppercase; margin-bottom: .25rem;
  }

  .scroll-hint {
    position: absolute; bottom: 2.2rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: .5rem;
    opacity: 0; animation: fadeUp 1s ease forwards 2.2s; z-index: 5;
  }
  .scroll-hint span {
    font-family: var(--mono); font-size: .52rem; letter-spacing: .3em;
    color: rgba(167,216,240,.25); text-transform: uppercase;
  }
  .scroll-line {
    width: 1px; height: 50px;
    background: linear-gradient(to bottom, var(--teal), transparent);
    animation: scrollAnim 2.3s ease-in-out infinite;
  }
  @keyframes scrollAnim {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .caustic { animation: none; }
    .scroll-line { animation: none; }
  }
</style>
