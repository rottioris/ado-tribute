---
---

<section id="gracias">
  <div class="gracias-bg">
    <img
      src="/images/Ado-ORIHARA.webp"
      alt="Ado"
      class="gracias-img"
      loading="eager"
      decoding="async"
    />
    <div class="gracias-overlay"></div>
  </div>

  <div class="inner gracias-inner">
    <div class="ty-content">

      <p class="ty-label reveal">Para Ado &nbsp;·&nbsp; アドへ</p>

      <blockquote class="ty-quote reveal">
        Hay voces que te cambian por dentro.<br />
        La tuya es de esas.
      </blockquote>

      <p class="ty-body reveal">
        No importa que nunca hayamos visto tu cara —
        te conocemos en cada nota, en cada palabra que gritas
        y en cada silencio que dejas entre ellas.
        Gracias por existir, Ado.
      </p>

      <div class="ty-cita reveal">
        <span class="ty-cita-jp">アドへ — あなたは私たちの世界を変えた</span>
        <span class="ty-cita-es">Nos cambiaste el mundo. Con amor, tus fans.</span>
      </div>

      <!-- CTAs directos -->
      <div class="ty-actions reveal">
        <a href="/fanarts" class="cta-primary">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Subir fan art
        </a>
        <a href="/messages" class="cta-secondary">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Dejar mensaje
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  #gracias {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--void);
  }

  /* ── Imagen fondo ── */
  .gracias-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .gracias-img {
    position: absolute;
    right: 10%;
    bottom: 0;
    height: 80%;
    width: auto;
    max-width: none;
    display: block;
    animation: floatAdo 7s ease-in-out infinite;
    transform-origin: bottom center;
  }

  @keyframes floatAdo {
    0%   { transform: translateY(0)    rotate(0deg); }
    30%  { transform: translateY(-10px) rotate(.3deg); }
    60%  { transform: translateY(-5px)  rotate(-.2deg); }
    100% { transform: translateY(0)    rotate(0deg); }
  }

  /* Overlay izquierda oscura → derecha transparente */
  .gracias-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right,
        rgba(4,5,10,.96)  0%,
        rgba(4,5,10,.88) 28%,
        rgba(4,5,10,.50) 52%,
        rgba(4,5,10,.0)  72%
      ),
      linear-gradient(to bottom,
        rgba(4,5,10,.7)  0%,
        transparent      12%,
        transparent      88%,
        rgba(4,5,10,.7) 100%
      );
  }

  /* ── Contenido ── */
  .gracias-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 7rem;
    padding-bottom: 7rem;
  }

  .ty-content {
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .ty-label {
    font-family: var(--mono);
    font-size: .58rem;
    letter-spacing: .45em;
    text-transform: uppercase;
    color: var(--teal);
  }

  .ty-quote {
    font-family: var(--ship);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    line-height: 1.3;
    color: var(--white);
    margin: 0;
    border: none;
    padding: 0;
  }

  .ty-body {
    font-family: var(--serif);
    font-size: .96rem;
    line-height: 2;
    color: var(--wdim);
    font-weight: 300;
    margin: 0;
  }

  .ty-cita {
    display: flex;
    flex-direction: column;
    gap: .4rem;
    border-left: 2px solid var(--teal);
    padding: .9rem 1.4rem;
    background: rgba(4,5,10,.45);
    backdrop-filter: blur(6px);
  }

  .ty-cita-jp {
    font-family: var(--ship);
    font-size: .85rem;
    color: var(--teal2);
    letter-spacing: .08em;
  }

  .ty-cita-es {
    font-family: var(--mono);
    font-size: .58rem;
    color: var(--wdim);
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  /* ── CTAs ── */
  .ty-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: .4rem;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-family: var(--mono);
    font-size: .62rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    padding: .85rem 1.6rem;
    border-radius: 2px;
    transition: all .3s;
    cursor: none;
  }

  .cta-primary {
    background: var(--teal);
    color: var(--void);
    font-weight: 700;
  }
  .cta-primary:hover {
    background: var(--teal2);
    transform: translateY(-2px);
  }

  .cta-secondary {
    border: 1px solid rgba(58,127,163,.4);
    color: var(--teal2);
    background: rgba(58,127,163,.06);
  }
  .cta-secondary:hover {
    border-color: var(--teal);
    background: rgba(58,127,163,.12);
    transform: translateY(-2px);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .gracias-img {
    position: absolute;
    right: 10%;
    bottom: 0;
    height: 80%;
    width: auto;
    max-width: none;
    display: block;
    animation: floatAdo 7s ease-in-out infinite;
    transform-origin: bottom center;
  }
    .gracias-overlay {
      background: rgba(4,5,10,.85);
    }
    .gracias-inner {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }
    .ty-content { max-width: 100%; }
    .ty-actions { flex-direction: column; }
    .cta-primary, .cta-secondary { justify-content: center; }
  }
</style>
