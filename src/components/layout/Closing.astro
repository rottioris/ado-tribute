<section id="cierre">
  <!-- Fades de fusión con secciones vecinas -->
  <div class="cierre-fade-top" aria-hidden="true"></div>
  <div class="cierre-fade-bottom" aria-hidden="true"></div>

  <canvas id="closingCanvas"></canvas>

  <div class="closing-inner">
    <p class="cl-jp reveal">ありがとう</p>
    <p class="cl-sub reveal">
      Gracias &nbsp;·&nbsp; Thank you &nbsp;·&nbsp; ありがとう
    </p>
    <div class="cl-langs reveal">
      <div class="cl-lang">
        <strong>Español</strong>
        Tu voz nos cambió la vida.<br />Gracias por existir, Ado.
      </div>
      <div class="cl-lang">
        <strong>English</strong>
        Your voice changed our lives.<br />Thank you for existing, Ado.
      </div>
      <div class="cl-lang">
        <strong>日本語</strong>
        あなたの声が私たちの人生を変えました。<br
        />存在してくれてありがとう、アド。
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const cv = document.getElementById("closingCanvas") as HTMLCanvasElement;
    if (!cv) return;
    const ctx = cv.getContext("2d")!;
    let W: number, H: number;
    interface B {
      x: number;
      y: number;
      r: number;
      a: number;
      s: number;
      t: number;
    }
    let bubbles: B[] = [];
    function resize() {
      W = cv.width = cv.offsetWidth;
      H = cv.height = cv.offsetHeight;
    }
    function spawn(): B {
      return {
        x: Math.random() * W,
        y: H + 40,
        r: 4 + Math.random() * 20,
        a: 0.05 + Math.random() * 0.12,
        s: 0.2 + Math.random() * 0.5,
        t: 0,
      };
    }
    function draw() {
      ctx.clearRect(0, 0, W, H);
      bubbles.forEach((b, i) => {
        b.t += 0.01;
        b.y -= b.s;
        b.x += Math.sin(b.t) * 0.5;
        ctx.beginPath();
        ctx.arc(b.x, b.y, b.r, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(167,216,240,${b.a})`;
        ctx.lineWidth = 0.8;
        ctx.stroke();
        if (b.y + b.r < 0) bubbles[i] = spawn();
      });
      requestAnimationFrame(draw);
    }
    resize();
    for (let i = 0; i < 20; i++) {
      const b = spawn();
      b.y = Math.random() * H;
      bubbles.push(b);
    }
    window.addEventListener("resize", resize);
    draw();
  })();
</script>

<style>
  #cierre {
    background: var(--void);
    text-align: center;
    /* Reducido de 10rem a 5rem */
    padding: 5rem 0;
    position: relative;
    overflow: hidden;
    /* Sin border — era la causa de las líneas blancas */
  }

  /* Fades de fusión — elementos dedicados, no ::before/::after */
  .cierre-fade-top,
  .cierre-fade-bottom {
    position: absolute;
    left: 0;
    right: 0;
    height: 100px;
    pointer-events: none;
    z-index: 3;
  }
  .cierre-fade-top {
    top: 0;
    background: linear-gradient(to bottom, var(--void), transparent);
  }
  .cierre-fade-bottom {
    bottom: 0;
    background: linear-gradient(to top, var(--void), transparent);
  }

  #closingCanvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .closing-inner {
    position: relative;
    z-index: 2;
  }

  .cl-jp {
    font-family: var(--ship);
    font-size: clamp(3.5rem, 10vw, 8rem);
    color: var(--white);
    line-height: 1;
    margin-bottom: 1.2rem;
  }

  .cl-sub {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.4em;
    color: var(--teal);
    text-transform: uppercase;
    margin-bottom: 2.5rem;
  }

  .cl-langs {
    display: flex;
    gap: 3.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cl-lang {
    font-family: var(--ship);
    font-size: 0.92rem;
    color: var(--wdim);
    font-weight: 300;
    line-height: 1.8;
  }
  .cl-lang strong {
    display: block;
    font-family: var(--mono);
    font-size: 0.5rem;
    letter-spacing: 0.25em;
    color: var(--teal);
    text-transform: uppercase;
    margin-bottom: 0.25rem;
    font-weight: 400;
  }
</style>
