---
import MessagesCarousel from './MessagesCarousel.tsx';
---

<section id="messages-preview">
  <div class="ms-fade-top"    aria-hidden="true"></div>
  <div class="ms-fade-bottom" aria-hidden="true"></div>

  <div class="inner ms-wrap">

    <div class="ms-header">
      <p class="s-label">02 — メッセージ</p>
      <h2 class="s-title">Mensajes para Ado</h2>
      <p class="s-sub">Palabras de fans · ファンからのメッセージ</p>
    </div>

    <!-- Carrusel contenido dentro del inner -->
    <MessagesCarousel client:load />

    <div class="ms-footer">
      <a href="/messages" class="btn-outline">Ver todos los mensajes →</a>
      <span class="ms-count">
        <span class="ms-num" id="msCount">—</span> mensajes
      </span>
    </div>

  </div>
</section>

<style>
  /* ── Sección ── */
  #messages-preview {
    position: relative;
    background: var(--void);
    padding: var(--section-pad) 0;
    overflow: hidden;
  }

  .ms-fade-top, .ms-fade-bottom {
    position: absolute;
    left: 0; right: 0; height: 100px;
    pointer-events: none; z-index: 3;
  }
  .ms-fade-top    { top: 0;    background: linear-gradient(to bottom, var(--void), transparent); }
  .ms-fade-bottom { bottom: 0; background: linear-gradient(to top,   var(--void), transparent); }

  .ms-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .ms-header { /* hereda s-label, s-title, s-sub */ }

  /* ── Root del carrusel ── */
  :global(.mc-root) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    width: 100%;
  }

  /* Stage con perspectiva 3D */
  :global(.mc-stage) {
    position: relative;
    width: 100%;
    height: 220px;
    perspective: 1200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Cards base ── */
  :global(.mc-card) {
    position: absolute;
    width: 340px;
    background: rgba(10,18,32,.7);
    border: 1px solid rgba(58,127,163,.14);
    border-radius: 8px;
    padding: 1.6rem 1.5rem 1.2rem;
    backdrop-filter: blur(10px);
    transition:
      transform .6s cubic-bezier(.25,.46,.45,.94),
      opacity   .6s ease,
      filter    .6s ease;
    will-change: transform, opacity;
    cursor: default;
    user-select: none;
  }

  /* Card activa — centro, plena visibilidad */
  :global(.mc-card[data-offset="0"]) {
    transform: translateX(0) translateZ(0) scale(1);
    opacity: 1;
    filter: none;
    z-index: 3;
    cursor: default;
    border-color: rgba(58,127,163,.28);
    background: rgba(12,22,40,.8);
  }

  /* Cards adyacentes — desplazadas, reducidas, atenuadas */
  :global(.mc-card[data-offset="1"]),
  :global(.mc-card[data-offset="-1"]) {
    opacity: .45;
    filter: blur(.5px);
    z-index: 2;
    cursor: pointer;
  }
  :global(.mc-card[data-offset="1"])  { transform: translateX(360px)  translateZ(-80px) scale(.88); }
  :global(.mc-card[data-offset="-1"]) { transform: translateX(-360px) translateZ(-80px) scale(.88); }

  /* Cards lejanas — casi invisibles */
  :global(.mc-card[data-offset="2"]),
  :global(.mc-card[data-offset="-2"]) {
    opacity: .15;
    filter: blur(1px);
    z-index: 1;
    cursor: pointer;
  }
  :global(.mc-card[data-offset="2"])  { transform: translateX(680px)  translateZ(-180px) scale(.76); }
  :global(.mc-card[data-offset="-2"]) { transform: translateX(-680px) translateZ(-180px) scale(.76); }

  /* Clases extra de offset para React */
  :global(.mc-card--offset-n2) { transform: translateX(-680px) translateZ(-180px) scale(.76); opacity:.15; filter:blur(1px); z-index:1; cursor:pointer; }
  :global(.mc-card--offset-n1) { transform: translateX(-360px) translateZ(-80px)  scale(.88); opacity:.45; filter:blur(.5px); z-index:2; cursor:pointer; }
  :global(.mc-card--offset-p0) { transform: translateX(0)      translateZ(0)      scale(1);   opacity:1;   filter:none;      z-index:3; border-color:rgba(58,127,163,.28); background:rgba(12,22,40,.8); }
  :global(.mc-card--offset-p1) { transform: translateX(360px)  translateZ(-80px)  scale(.88); opacity:.45; filter:blur(.5px); z-index:2; cursor:pointer; }
  :global(.mc-card--offset-p2) { transform: translateX(680px)  translateZ(-180px) scale(.76); opacity:.15; filter:blur(1px); z-index:1; cursor:pointer; }

  /* ── Contenido de la card ── */
  :global(.mc-quote) {
    font-family: var(--ship);
    font-size: 4rem;
    color: rgba(58,127,163,.1);
    position: absolute;
    top: -.3rem; left: .8rem;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  :global(.mc-text) {
    font-family: var(--ship);
    font-size: .87rem;
    line-height: 1.85;
    color: rgba(220,238,250,.65);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1.1rem;
    position: relative;
    z-index: 1;
    font-style: italic;
  }

  :global(.mc-footer) {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: .5rem;
  }
  :global(.mc-author) { display: flex; flex-direction: column; gap: .15rem; }
  :global(.mc-name) {
    font-family: var(--ship);
    font-size: .84rem;
    color: var(--white);
  }
  :global(.mc-country) {
    font-family: var(--mono);
    font-size: .5rem;
    color: rgba(58,127,163,.7);
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  :global(.mc-song) {
    font-family: var(--mono);
    font-size: .48rem;
    color: rgba(167,216,240,.38);
    letter-spacing: .1em;
    border: 1px solid rgba(58,127,163,.15);
    padding: 3px 7px;
    border-radius: 2px;
    white-space: nowrap;
    align-self: flex-end;
  }

  /* ── Navegación ── */
  :global(.mc-nav) {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  :global(.mc-btn) {
    width: 36px; height: 36px;
    border: 1px solid rgba(58,127,163,.25);
    border-radius: 50%;
    background: rgba(10,18,32,.6);
    color: var(--teal2);
    display: flex; align-items: center; justify-content: center;
    cursor: none;
    transition: border-color .3s, background .3s;
    flex-shrink: 0;
  }
  :global(.mc-btn:hover) {
    border-color: rgba(58,127,163,.6);
    background: rgba(58,127,163,.1);
  }

  :global(.mc-dots) {
    display: flex;
    gap: .5rem;
    align-items: center;
  }
  :global(.mc-dot) {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(58,127,163,.25);
    border: none;
    cursor: none;
    transition: background .3s, transform .3s;
    padding: 0;
  }
  :global(.mc-dot--active) {
    background: var(--teal);
    transform: scale(1.4);
  }

  /* ── Footer sección ── */
  .ms-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .ms-count {
    font-family: var(--mono);
    font-size: .58rem;
    color: var(--wdim);
    letter-spacing: .15em;
  }
  .ms-num {
    color: var(--teal2);
    font-size: .75rem;
    font-weight: 700;
    margin-right: .3rem;
  }

  @media (max-width: 768px) {
    :global(.mc-stage) { height: 260px; }
    :global(.mc-card)  { width: 280px; }
    :global(.mc-card[data-offset="1"])  { transform: translateX(300px)  translateZ(-60px) scale(.85); }
    :global(.mc-card[data-offset="-1"]) { transform: translateX(-300px) translateZ(-60px) scale(.85); }
    :global(.mc-card[data-offset="2"]),
    :global(.mc-card[data-offset="-2"]) { opacity: 0; pointer-events: none; }
  }
</style>
