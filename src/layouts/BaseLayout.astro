---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Ado Tribute',
  description = 'Un tributo de fans para Ado (アド), la artista japonesa. Sube tu fan art, deja tu mensaje y celebra su música junto a fans de todo el mundo.',
  ogImage = '/images/og-cover.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://ado-tribute.vercel.app');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#04050a" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:locale"      content="es_LA" />
    <meta property="og:site_name"   content="Ado Tribute" />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Keywords -->
    <meta name="keywords" content="Ado, アド, fan tribute, fan art, Usseewa, Vivarium, ビバリウム, New Genesis, Tot Musica, música japonesa, J-pop, fans latinoamérica" />
    <meta name="author" content="rottioris" />
    <meta name="robots" content="index, follow" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;700&family=Shippori+Mincho:wght@400;700&family=Space+Mono:wght@400;700&family=Zen+Antique+Soft&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="cur" id="cur"></div>
    <div class="cur-ring" id="curRing"></div>

    <div id="bubbles" style="position:fixed;inset:0;pointer-events:none;z-index:0">
      <canvas id="bubbleCanvas" style="position:absolute;inset:0;width:100%;height:100%"></canvas>
    </div>

    <slot />

    <div class="toast" id="toast"></div>

    <script>
      const cur = document.getElementById('cur')!;
      const curRing = document.getElementById('curRing')!;
      document.addEventListener('mousemove', (e) => {
        cur.style.left = e.clientX + 'px';
        cur.style.top  = e.clientY + 'px';
        setTimeout(() => {
          curRing.style.left = e.clientX + 'px';
          curRing.style.top  = e.clientY + 'px';
        }, 90);
      });
      document.querySelectorAll('a,button,.fa-card,.upzone,input,textarea,select').forEach(el => {
        el.addEventListener('mouseenter', () => { cur.style.width='16px'; cur.style.height='16px'; (cur.style as any).background='#F59BB0'; });
        el.addEventListener('mouseleave', () => { cur.style.width='8px';  cur.style.height='8px';  (cur.style as any).background='#A7D8F0'; });
      });

      new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('on'); } });
      }, { threshold: 0.12 }).observe(document.body);

      document.querySelectorAll('.reveal').forEach(el => {
        new IntersectionObserver(([e]) => {
          if (e.isIntersecting) { el.classList.add('on'); }
        }, { threshold: 0.12 }).observe(el);
      });

      (window as any).showToast = (msg: string) => {
        const t = document.getElementById('toast')!;
        t.textContent = msg;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3800);
      };

      (function () {
        const cv = document.getElementById('bubbleCanvas') as HTMLCanvasElement;
        const ctx = cv.getContext('2d')!;
        let W: number, H: number;
        interface B { x:number;y:number;r:number;alpha:number;speed:number;wobble:number;wobbleSpeed:number;wobbleOffset:number;t:number; }
        let bubbles: B[] = [];
        function resize() { W = cv.width = window.innerWidth; H = cv.height = window.innerHeight; }
        function spawn(): B {
          return { x:Math.random()*W, y:H+Math.random()*100, r:6+Math.random()*28,
            alpha:.04+Math.random()*.14, speed:.15+Math.random()*.4,
            wobble:.3+Math.random()*.8, wobbleSpeed:.008+Math.random()*.012,
            wobbleOffset:Math.random()*Math.PI*2, t:0 };
        }
        function draw() {
          ctx.clearRect(0,0,W,H);
          bubbles.forEach((b,i) => {
            b.t+=b.wobbleSpeed; b.y-=b.speed; b.x+=Math.sin(b.t+b.wobbleOffset)*b.wobble;
            const g=ctx.createRadialGradient(b.x-b.r*.3,b.y-b.r*.3,b.r*.05,b.x,b.y,b.r);
            g.addColorStop(0,`rgba(167,216,240,${b.alpha*.6})`);
            g.addColorStop(.6,`rgba(58,127,163,${b.alpha*.3})`);
            g.addColorStop(1,`rgba(30,50,90,0)`);
            ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2); ctx.fillStyle=g; ctx.fill();
            ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2);
            ctx.strokeStyle=`rgba(167,216,240,${b.alpha*.5})`; ctx.lineWidth=.5; ctx.stroke();
            if(b.y+b.r<0) bubbles[i]=spawn();
          });
          requestAnimationFrame(draw);
        }
        resize();
        for(let i=0;i<28;i++){const b=spawn();b.y=Math.random()*H;bubbles.push(b);}
        window.addEventListener('resize',resize);
        draw();
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/globals.css';
</style>
